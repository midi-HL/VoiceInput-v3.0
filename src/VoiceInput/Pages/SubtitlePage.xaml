<Page
    x:Class="VoiceInput.Pages.SubtitlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="12" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="实时字幕" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="实时语音转文字 按住右 Alt 键开始记录" FontSize="13" Foreground="#999999" Margin="0,0,0,12" />

        <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE1D6;" FontSize="16" Foreground="#0078D4" />
                    <TextBlock x:Name="StatusTxt" Text="空闲" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="32,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="语言:" FontSize="13" Foreground="#999999" />
                    <TextBlock x:Name="LanguageTxt" Text="自动检测" FontSize="13" Foreground="#FFFFFF" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12">
                    <Button Content="清空" Click="OnClearClick" Background="Transparent" BorderBrush="#555555" BorderThickness="1" Foreground="#FFFFFF" Padding="12,6" />
                    <Button Content="复制" Click="OnCopyClick" Background="Transparent" BorderBrush="#555555" BorderThickness="1" Foreground="#FFFFFF" Padding="12,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="8" Padding="20">
            <ScrollViewer x:Name="ScrollContainer" VerticalScrollBarVisibility="Auto">
                <RichTextBlock x:Name="SubtitleBox" LineHeight="28" LineStackingStrategy="MaxHeight">
                    <Paragraph FontFamily="Segoe UI Variable" FontSize="16" Foreground="#FFFFFF">
                        <Run Text="字幕内容将在这里实时显示..." Foreground="#555555" />
                    </Paragraph>
                </RichTextBlock>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
