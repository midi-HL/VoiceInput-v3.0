<Page
    x:Class="VoiceInput.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid VerticalAlignment="Top" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="欢迎使用语音输入" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,6" />
        <TextBlock Grid.Row="1" Text="选择下方功能开始使用" FontSize="14" Foreground="#999999" Margin="0,0,0,32" />

        <GridView Grid.Row="2" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnCardClick" HorizontalAlignment="Stretch">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" ItemWidth="330" ItemHeight="130" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <Border Background="#2D2D2D" CornerRadius="8" Margin="8" Padding="16" Tag="Lyrics">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE189;" FontSize="28" Foreground="#0078D4" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="歌词识别" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                        <TextBlock Text="上传音频文件 自动识别并生成歌词" FontSize="12" Foreground="#999999" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#2D2D2D" CornerRadius="8" Margin="8" Padding="16" Tag="Subtitle">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE104;" FontSize="28" Foreground="#0078D4" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="实时字幕" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                        <TextBlock Text="实时语音转文字 支持多语言" FontSize="12" Foreground="#999999" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#2D2D2D" CornerRadius="8" Margin="8" Padding="16" Tag="QuickInput">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE1D6;" FontSize="28" Foreground="#0078D4" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="快速输入" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                        <TextBlock Text="使用快捷键：按住右Alt键说话" FontSize="12" Foreground="#999999" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#2D2D2D" CornerRadius="8" Margin="8" Padding="16" Tag="Settings">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="28" Foreground="#0078D4" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="设置" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" />
                        <TextBlock Text="配置 API、语言、快捷键等选项" FontSize="12" Foreground="#999999" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </GridView>
    </Grid>
</Page>
