<Window
    x:Class="VoiceInput.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="语音输入">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
            <Grid Padding="12,24,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,0,0,24">
                    <FontIcon Glyph="&#xE720;" FontSize="20" Foreground="#0078D4" />
                    <TextBlock Text="语音输入" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Spacing="6" x:Name="NavList">
                    <Button x:Name="HomeBtn" Click="OnNavClick" Tag="Home" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Background="Transparent" BorderThickness="0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE10F;" FontSize="16" Foreground="#FFFFFF" />
                            <TextBlock Text="主页" FontSize="14" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LyricsBtn" Click="OnNavClick" Tag="Lyrics" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Background="Transparent" BorderThickness="0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE189;" FontSize="16" Foreground="#999999" />
                            <TextBlock Text="歌词识别" FontSize="14" Foreground="#999999" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SubtitleBtn" Click="OnNavClick" Tag="Subtitle" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Background="Transparent" BorderThickness="0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE104;" FontSize="16" Foreground="#999999" />
                            <TextBlock Text="实时字幕" FontSize="14" Foreground="#999999" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer Setting -->
                <StackPanel Grid.Row="2" Spacing="4">
                    <Border Height="1" Background="#2A2A2A" Margin="0,0,0,12" />
                    <Button x:Name="SettingsBtn" Click="OnNavClick" Tag="Settings" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Background="Transparent" BorderThickness="0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="#999999" />
                            <TextBlock Text="设置" FontSize="14" Foreground="#999999" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Content Area -->
        <Border Grid.Column="1" Background="#121212" Padding="24">
            <Frame x:Name="ContentFrame" NavigationFailed="OnNavigationFailed" />
        </Border>
    </Grid>
</Window>
